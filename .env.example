# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Access Control (comma-separated list of authorized telegram user IDs)
# Leave empty to allow anyone, but highly recommended to specify your ID.
AUTHORIZED_USERS=

# Google Drive / Rclone Configuration
RCLONE_REMOTE_NAME=gdrive
RCLONE_UPLOAD_DIR=TelegramBotUploads

# Local Storage Configuration
DOWNLOAD_DIR=./downloads

# Concurrency limits
MAX_CONCURRENT_JOBS=2
